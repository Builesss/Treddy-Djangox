@startuml arquitectura_mvt
!theme bluegray

skinparam componentStyle rectangle

node "Cliente (Navegador)" as browser {
    [HTML5 / CSS3 / JS]
    [Fetch API (SPA)]
    [SweetAlert2 & NProgress]
}

node "Servidor Django (Backend)" as django {
    package "Capa de Presentación (Template)" as templates {
        [base.html]
        [dashboards/*.html]
        [productos/*.html]
    }
    
    package "Capa Lógica (View)" as views {
        [usuarios/views.py]
        [productos/views.py]
    }
    
    package "Capa de Datos (Model)" as models {
        [usuarios/models.py]
        [productos/models.py]
    }
}

database "Base de Datos (SQLite)" as db {
    [Tablas: Usuario, Producto, Historial]
}

browser <--> views : "Peticiones HTTP/AJAX (GET, POST)"
views <--> models : "Lectura / Escritura (ORM)"
models <--> db : "Consultas SQL (Singleton Connection)"
views --> templates : "Renderiza Contexto"
templates --> browser : "Respuesta HTML (Bloques SPA)"

@enduml
